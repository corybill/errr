{
  "name": "errr",
  "version": "4.0.1",
  "description": "Error factory with the ability to append stack traces from previous errors, as well as appending debug params to stack traces.  Great if you want one appended stack trace that defines the error at many levels of your code.  This concept works wonders when using promise chains because you get the stack trace at each level of your code.",
  "type": "module",
  "main": "./dist/errr.cjs",
  "module": "./lib/errr.js",
  "types": "./lib/errr.d.ts",
  "exports": {
    ".": {
      "types": "./lib/errr.d.ts",
      "import": "./lib/errr.js",
      "require": "./dist/errr.cjs",
      "default": "./lib/errr.js"
    }
  },
  "files": [
    "lib",
    "dist"
  ],
  "scripts": {
    "build:cjs": "node scripts/build-cjs.mjs",
    "prepack": "npm run build:cjs",
    "check:types": "tsc --noEmit",
    "test": "npm run build:cjs && npm run check:types && npm run ut && npm run lint",
    "ut": "vitest run",
    "perf": "env perf=true env test=false maddox ./spec/unit",
    "uap": "env perf=true test=true maddox ./spec/unit",
    "coverage": "./bin/maddox-cov.js",
    "lint": "eslint ./spec/ ./lib ./scripts/**/*.mjs",
    "docs": " ./node_modules/jsdoc-to-markdown/bin/cli.js \"./lib/**/*.js\" > api.md",
    "publish:npm": "bash scripts/publish.sh",
    "deploy": "npm run publish:npm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/corybill/errr.git"
  },
  "keywords": [
    "StriveNine",
    "Strive9",
    "Error",
    "Error Factory",
    "Error Builder",
    "Stack Trace",
    "Appendable",
    "Debug Params",
    "Promise",
    "Promise Chain",
    "appendable",
    "concat",
    "concatenate",
    "err",
    "set values"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "corybill",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/corybill/errr/issues"
  },
  "homepage": "https://github.com/corybill/errr#readme",
  "overrides": {
    "diff": "^5.2.1",
    "js-yaml": "^4.1.1",
    "nanoid": "^3.3.8",
    "serialize-javascript": "^7.0.5",
    "mocha": {
      "minimatch": "^9.0.5"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "chance": "^1.1.13",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jsdoc": "^4.0.5",
    "jsdoc-to-markdown": "^9.1.3",
    "maddox": "^3.0.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
